<Page x:Class="RemoteSystemWpf.Pages.ServerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Сервер удаленного доступа"
      Unloaded="Page_Unloaded">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/RemoteSystemWpf;component/Images/DefaultBackground.jpg" 
                   Stretch="UniformToFill"/>
        </Grid.Background>
        

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.6*"/>
        </Grid.ColumnDefinitions>

        <Rectangle Grid.Column="0" Fill="#40000000"/>
        <Rectangle Grid.Column="1" Fill="#40000000"/>

        <Grid Grid.Column="0">
            <Border CornerRadius="10"
                BorderBrush="Black"
                BorderThickness="2"
                Background="#80FFFFFF" 
                Margin="10,10,0,0" 
                Width="150" 
                Height="30" 
                VerticalAlignment="Top" 
                HorizontalAlignment="Left" >
                <Button x:Name="Backbtn" 
                    Click="Back_Click"   
                    Content="Назад"
                    Width="150" 
                    Height="30" 
                    Margin="-2,-2,-2,-2"
                    Background="Transparent" 
                    BorderBrush="Transparent"
                    VerticalContentAlignment="Center" 
                    HorizontalContentAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>

            
            <Border CornerRadius="10"
                    BorderBrush="Black"
                    BorderThickness="2"
                    Background="#80FFFFFF" 
                    Margin="10,0,0,10" 
                    Width="150" 
                    Height="30" 
                    VerticalAlignment="Bottom" 
                    HorizontalAlignment="Left" >
                <Button x:Name="Startbtn" 
                     Click="Start_Click"
                     Background="Transparent" 
                     BorderBrush="Transparent"
                     Content="Запустить" 
                     Width="150" 
                     Height="30"
                     Margin="-2,-2,-2,-2"
                     VerticalContentAlignment="Center" 
                     HorizontalContentAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>

            <Border CornerRadius="10"
                BorderBrush="Black"
                BorderThickness="2"
                Background="#80FFFFFF" 
                Margin="170,0,0,10" 
                Width="150" 
                Height="30" 
                VerticalAlignment="Bottom" 
                HorizontalAlignment="Left" >
                <Button x:Name="Stopbtn" 
                     Click="Stop_Click" 
                     IsEnabled="False"  
                     Content="Остановить"
                     Width="150" 
                     Height="30" 
                     Margin="-2,-2,-2,-2"
                     Background="Transparent" 
                     BorderBrush="Transparent"
                     VerticalContentAlignment="Center" 
                     HorizontalContentAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Margin="10,10,10,10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Gray"
                BorderBrush="Black" 
                BorderThickness="2"
                CornerRadius="5">

            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" 
                        Content="События" 
                        FontSize="15" 
                        FontWeight="Bold"
                        HorizontalContentAlignment="Center"
                        Margin="0,0,0,5"/>

                <ListBox x:Name="LogBox" 
                        Grid.Row="1"
                        Background="Transparent" 
                        BorderBrush="Transparent"
                        FontSize="15"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Page>