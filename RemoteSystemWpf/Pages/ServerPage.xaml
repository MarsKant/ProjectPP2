<Page x:Class="RemoteSystemWpf.Pages.ServerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:RemoteSystemWpf.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Сервер удаленного доступа">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/RemoteSystemWpf;component/Images/DefaultBackground.jpg" 
                   Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0.4*"/>
        </Grid.ColumnDefinitions>

        <Rectangle Grid.Column="0" Fill="#40000000"/>

        <Rectangle Grid.Column="1" Fill="#40000000"/>

        <Grid Grid.Column="0">
            <Label Margin="0,10,0,0" 
                   Content="Порт:" 
                   Width="40" Height="30" 
                   VerticalAlignment="Top" 
                   HorizontalAlignment="Left" 
                   VerticalContentAlignment="Center"
                   Foreground="White"
                   FontWeight="Bold"/>

        <TextBox Margin="50,10,0,0" 
                 x:Name="portBox"
                 TextWrapping="Wrap" 
                 Width="100" 
                 Height="30" 
                 VerticalAlignment="Top" 
                 HorizontalAlignment="Left"
                 VerticalContentAlignment="Center"
                 Background="#80FFFFFF"
                 Text="3006"/>

        <Button x:Name="Startbtn" 
                 Click="Start" 
                 Margin="40,0,0,10" 
                 Background="#F5DEB3"  
                 Content="Запустить" 
                 Width="150" 
                 Height="30" 
                 VerticalAlignment="Bottom" 
                 HorizontalAlignment="Left"/>

        <Button x:Name="Stopbtn" 
                 Click="Stop" 
                 Margin="200,0,0,10" 
                 Background="#F5DEB3" 
                 IsEnabled="False"  
                 Content="Остановить" 
                 Width="150" 
                 Height="30" 
                 VerticalAlignment="Bottom" 
                 HorizontalAlignment="Left"/>
        </Grid>

        <Border Grid.Column="1"
                Margin="10,10,10,10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="#80FFFFFF"
                BorderBrush="Black" 
                BorderThickness="2"
                CornerRadius="5">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" 
                        Content="События" 
                        FontSize="15" 
                        FontWeight="Bold"
                        HorizontalContentAlignment="Center"
                        Margin="0,0,0,5"/>

                <ListBox x:Name="LogBox" 
                        Grid.Row="1"
                        Background="Transparent" 
                        BorderBrush="Transparent"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Page>
