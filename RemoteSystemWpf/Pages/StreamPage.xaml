<Page x:Class="RemoteSystemWpf.Pages.StreamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Трансляция экрана"
      Unloaded="Page_Unloaded"
      Focusable="True" Background="Black">

    <Grid x:Name="VideoGrid">
        <vlc:VideoView x:Name="VideoView_Display" />

        <Popup x:Name="InputPopup" 
               PlacementTarget="{Binding ElementName=VideoView_Display}" 
               Placement="Center"
               StaysOpen="True"
               AllowsTransparency="True"
               Focusable="False">
            <Border x:Name="VideoView_Commands" 
                    Background="#01000000"
                    MouseDown="InputOverlay_MouseDown"
                    MouseMove="InputOverlay_MouseMove"
                    MouseUp="InputOverlay_MouseUp"
                    MouseWheel="InputOverlay_MouseWheel"
                    Focusable="True"/>
        </Popup>

        <Button Content="Отключиться (Esc)" 
                Click="Disconnect_Click" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Top" 
                Margin="10" 
                Padding="15,5" 
                Background="#CCFFFFFF" 
                BorderBrush="Transparent"
                Panel.ZIndex="10"/>
    </Grid>
</Page>