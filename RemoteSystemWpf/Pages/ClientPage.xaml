<Page x:Class="RemoteSystemWpf.Pages.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Клиент удаленного доступа"
      Unloaded="Page_Unloaded"
      Focusable="True">

    <Grid x:Name="MainRoot">
        <Grid x:Name="BackgroundLayer">
            <Grid.Background>
                <ImageBrush ImageSource="pack://application:,,,/RemoteSystemWpf;component/Images/DefaultBackground.jpg" 
                            Stretch="UniformToFill"/>
            </Grid.Background>
            <Rectangle Fill="#40000000"/>
        </Grid>

        <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="RowTop" Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="ConnectionPanel" Grid.Row="0" Background="#CCFFFFFF" BorderBrush="Black" BorderThickness="1.5" CornerRadius="6" Padding="10" Margin="15,15,15,10">
                <StackPanel>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="IP сервера:" FontSize="14" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="IpBox" Text="127.0.0.1" Height="28"/>
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Порт:" FontSize="14" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="PortBox" Text="8554" Height="28"/>
                    </Grid>
                    <UniformGrid Columns="2" Margin="0,5,0,0">
                        <Button x:Name="ConnectBtn" Content="Подключиться" Click="Connect" Height="30" Margin="0,0,5,0"/>
                        <Button x:Name="DisconnectBtn" Content="Отключиться" Click="Disconnect" Height="30" Margin="5,0,0,0" IsEnabled="False"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border x:Name="VideoContainer" Grid.Row="1" Background="Black" CornerRadius="8" Margin="15,0,15,15">
                <Grid x:Name="VideoGrid">
                    <vlc:VideoView x:Name="VideoView_Display" />

                    <Popup x:Name="InputPopup" 
                           PlacementTarget="{Binding ElementName=VideoView_Display}" 
                           Placement="Center"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           Focusable="False">
                        <Border x:Name="VideoView_Commands" 
                                Background="#01000000"
                                MouseDown="InputOverlay_MouseDown"
                                MouseMove="InputOverlay_MouseMove"
                                MouseUp="InputOverlay_MouseUp"
                                MouseWheel="InputOverlay_MouseWheel"
                                Focusable="True"/>
                    </Popup>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>